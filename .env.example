# Used for canonical URLs, sitemap, robots, and Open Graph base resolution.
NEXT_PUBLIC_SITE_URL=https://xlashbyyane.com

# Stripe — get keys from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend API key (https://resend.com). Server-only.
RESEND_API_KEY=

# Verified sender for transactional email (must be a domain verified in Resend).
# Example: "Hello You Wellness <no-reply@helloyouwellness.com>"
CONTACT_FROM_EMAIL=

# Where contact form submissions and newsletter signups are delivered.
CONTACT_NOTIFICATION_EMAIL=info@helloyouwellness.com

# Optional — Resend Audience ID to add newsletter signups to a list.
RESEND_AUDIENCE_ID=

# Analytics — Google Tag Manager container ID (format: GTM-XXXXXXX).
# Also required: GA4 Measurement ID configured as a tag inside the GTM container.
# When unset, all analytics scripts no-op (safe for local dev / previews).
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_FB_PIXEL_ID=  # phase 2, when paid launches

# Cookiebot CMP — required for Consent Mode v2 to move off default-denied in prod.
# Sign up at https://www.cookiebot.com/, add helloyouwellness.com as a domain,
# copy the CBID (UUID) from Settings → Your scripts.
# When unset, the CMP script no-ops and GA4/Ads tags never fire in prod.
NEXT_PUBLIC_COOKIEBOT_CBID=

# Twilio SMS — powers the post-visit review request texts sent from /admin.
# Sign up at https://www.twilio.com/, buy a US number, then paste:
#   Account SID  → console.twilio.com → Account Info
#   Auth Token   → console.twilio.com → Account Info (reveal)
#   From phone   → in E.164 format, e.g. +17865551234
# When unset, /admin still creates review-request links but the SMS is skipped —
# mom can copy the link and send via WhatsApp or personal text.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# Vercel Cron secret — protects /api/cron/* endpoints (weekly-digest,
# birthday-perk, win-back) from being hit by anyone but Vercel's cron runner.
# Set to any long random string and Vercel will send it as
# `Authorization: Bearer <secret>` on scheduled invocations. See vercel.json.
CRON_SECRET=

# Cal.com webhook secret — validates POST /api/webhooks/cal-com so we only
# process real Cal.com webhook events. Setup in Cal.com:
#   Settings → Developer → Webhooks → New webhook
#   URL:    https://helloyouwellness.com/api/webhooks/cal-com
#   Secret: match this env var
#   Subscribe: BOOKING_CREATED, BOOKING_CANCELLED, BOOKING_RESCHEDULED
# When unset, signature validation is skipped — safe for local dev, but MUST
# be set before pointing production Cal.com at the endpoint.
CAL_WEBHOOK_SECRET=

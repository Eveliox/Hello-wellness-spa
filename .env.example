# Used for canonical URLs, sitemap, robots, and Open Graph base resolution.
NEXT_PUBLIC_SITE_URL=https://xlashbyyane.com

# Stripe — get keys from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend API key (https://resend.com). Server-only.
RESEND_API_KEY=

# Verified sender for transactional email (must be a domain verified in Resend).
# Example: "Hello You Wellness <no-reply@helloyouwellness.com>"
CONTACT_FROM_EMAIL=

# Where contact form submissions and newsletter signups are delivered.
CONTACT_NOTIFICATION_EMAIL=info@helloyouwellness.com

# Optional — Resend Audience ID to add newsletter signups to a list.
RESEND_AUDIENCE_ID=
